[user]
	name = Arnau Llamas
	email = arnau.llamas@gmail.com
	signingkey = ~/.ssh/github-signing.pub

[commit]
	gpgsign = true

[gpg]
	format = ssh

[init]
	defaultBranch = main

[pull]
	rebase = true

[diff]
    external = difft

[url "https://github.com"]
	insteadOf = git://github.com

[credential]
	helper = cache --timeout=604800
